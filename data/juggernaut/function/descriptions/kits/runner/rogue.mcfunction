item replace entity @s hotbar.8 with written_book[written_book_content={title:"Rogue",author:"§9Server",pages:[\
[{"text": "Rogue\n\n","bold": true,"color": "#6A4ECC","underlined": false},\
 {"text": "A slippery runner who slips through tight spaces and vanishes when cornered.","bold": false,"color": "black"}],\
\
[{"text": "Stealth Expertise\n","bold": true,"color": "#6A4ECC"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "While crouching, your step height is increased, allowing you to walk up full blocks. Your crouch speed is also greatly increased.","bold": false,"color": "black"}],\
\
[{"text": "Smoke Bomb\n","bold": true,"color": "#6A4ECC"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Deploy a smoke cloud that obscures the Juggernaut's vision and become invisible for 6 seconds.","bold": false,"color": "black"},{"text": "\nCooldown: 1m","bold": false,"color": "dark_gray"}],\
\
[{"text": "Backstep\n","bold": true,"color": "#6A4ECC"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Emit a burst of sparks and teleport directly behind the Juggernaut.","bold": false,"color": "black"},{"text": "\nCooldown: 1m","bold": false,"color": "dark_gray"}]]\
}]