item replace entity @s hotbar.8 with written_book[written_book_content={title:"Engineer",author:"§9Server",pages:[\
[{"text": "Engineer\n\n","bold": true,"color": "#9B30FF","underlined": false},\
 {"text": "A tactical support runner who deploys towers to hinder the Juggernaut and keep teammates alive.","bold": false,"color": "black"}],\
\
[{"text": "Spawn Revealing Tower\n","bold": true,"color": "#9B30FF"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Place a tower that is invisible until the Juggernaut comes within 8 blocks. When they do, it reveals itself and applies glowing to them. The Juggernaut can stand near it to dispel it.","bold": false,"color": "black"},{"text": "\nCooldown: 1m 30s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Spawn Replenishment Tower\n","bold": true,"color": "#9B30FF"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Place a tower that acts as an additional replenishment station, usable only by Engineers. The Juggernaut can stand near it to dispel it.","bold": false,"color": "black"},{"text": "\nCooldown: 1m","bold": false,"color": "dark_gray"}],\
\
[{"text": "Spawn Turret\n","bold": true,"color": "#9B30FF"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Place a skeleton turret that shoots at the Juggernaut. The Juggernaut can stand near it to dispel it.","bold": false,"color": "black"},{"text": "\nCooldown: 1m 30s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Borrowed Time\n","bold": true,"color": "#9B30FF"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Become temporarily invulnerable. Afterwards, 75% of all damage taken during that window is dealt back to you as damage over time.","bold": false,"color": "black"},{"text": "\nCooldown: 2m","bold": false,"color": "dark_gray"}]]\
}]