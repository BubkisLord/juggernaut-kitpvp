item replace entity @s hotbar.8 with written_book[written_book_content={title:"Windrunner",author:"§9Server",pages:[\
[{"text": "Windrunner\n\n","bold": true,"color": "#13a0ca","underlined": false},\
 {"text": "A momentum-based sprinter who grows faster the longer they run.","bold": false,"color": "black"}],\
\
[{"text": "Sprint Momentum\n","bold": true,"color": "#13a0ca"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "Gain stacking speed every tick you maintain a sprint. Stacks build up to a cap at 450 ticks (22.5s) of continuous sprinting. Stopping your sprint resets all stacks after a timeout period of ~0.7 seconds.","bold": false,"color": "black"}],\
\
[{"text": "Risky Business\n","bold": true,"color": "#13a0ca"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Give the Juggernaut a speed boost, but double your own replenishment contribution for 10 seconds. High risk, high reward - best used when you already have momentum and confident you can escape.","bold": false,"color": "black"},{"text": "\nCooldown: 40s","bold": false,"color": "dark_gray"}]]\
}]