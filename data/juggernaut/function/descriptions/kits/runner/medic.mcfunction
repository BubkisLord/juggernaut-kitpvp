item replace entity @s hotbar.8 with written_book[written_book_content={title:"Medic",author:"§9Server",pages:[\
[{"text": "Medic\n\n","bold": true,"color": "#3BCC3B","underlined": false},\
 {"text": "A selfless runner who keeps teammates healthy and rushes to those in need.","bold": false,"color": "black"}],\
\
[{"text": "Field Medicine\n","bold": true,"color": "#3BCC3B"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You heal other runners at double speed. Other Runners also gain Regeneration I when in 5 blocks of you.","bold": false,"color": "black"}],\
\
[{"text": "Rescue\n","bold": true,"color": "#3BCC3B"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Teleport to another runner. If no runners remain, teleport to a spawn point instead. Cannot be used while the Juggernaut is within 20 blocks of you.","bold": false,"color": "black"},{"text": "\nCooldown: 60s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Heal\n","bold": true,"color": "#3BCC3B"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Heal all runners within 8 blocks of you. You gain Regeneration I.","bold": false,"color": "black"},{"text": "All other players you use this ability on have their cooldowns halved.","bold": false,"color": "black"},{"text": "\nCooldown: 1m","bold": false,"color": "dark_gray"}]]\
}]