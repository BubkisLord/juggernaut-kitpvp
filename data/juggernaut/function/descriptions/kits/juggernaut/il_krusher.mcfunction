item replace entity @s hotbar.8 with written_book[written_book_content={pages:[[{"text": "Il Krusher\n\n","bold": true,"color": "#c0392b","underlined": false},{"text": "An unstoppable wall of netherite. Il Krusher trades finesse for raw momentum, lowering his shoulder and charging straight through anyone foolish enough to stand in his way.","bold": false,"color": "black"}],\
[{"text": "Crushing Dash\n","bold": true,"color": "#c0392b"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Charge forward in the direction you are facing. Any runner caught in the charge is dealt damage and knocked back, once per dash. The charge stops when it slams into a wall.","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "#c0392b"},{"text": "The dash only travels in a straight horizontal line, so break line of sight and force Il Krusher around corners. Bait the dash early, then juke sideways while it is on cooldown to open up distance.","bold": false,"color": "black"}]],title: "Il Krusher",author:"§9Server"}]
