item replace entity @s hotbar.8 with written_book[written_book_content={title:"Dragon",author:"§9Server",pages:[\
[{"text": "Dragon\n\n","bold": true,"color": "#5c2787","underlined": false},\
 {"text": "An aerial Juggernaut that overwhelms Runners with flight and devastating breath attacks from above.","bold": false,"color": "black"}],\
\
[{"text": "Gliding Wings\n","bold": true,"color": "#5c2787"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You cannot take fall damage. Your sneaking speed is massively increased, allowing precise aerial descents.","bold": false,"color": "black"}],\
\
[{"text": "Switch to Floating\n","bold": true,"color": "#5c2787"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Activate automated floating mode. Your gravity is controlled automatically to keep you hovering at a fixed height above the ground.\n\nIf no ground is detected within 5 blocks below you,","bold": false,"color": "black"}],\
\
[{"text": "Switch to Floating\n","bold": true,"color": "#5c2787"},{"text": "cont.\n\n","bold": true,"color": "gray","italic": true},{"text": "gravity reverses and you rise. Once ground is detected, gravity is neutralised to hold your altitude. If you descend too close to the surface (within 0.75 blocks), normal gravity resumes and floating mode is automatically disabled.","bold": false,"color": "black"}],\
\
[{"text": "Switch to Floating\n","bold": true,"color": "#5c2787"},{"text": "cont.\n\n","bold": true,"color": "gray","italic": true},{"text": "Crouching while floating applies a mild downward gravity, letting you descend in a controlled manner.\n\n","bold": false,"color": "black"},{"text":"Cooldown: 0s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Switch to Flight\n","bold": true,"color": "#5c2787"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Switch from floating mode to manual flight mode. Your gravity is set to an upward drift keeping you airborne automatically.\nCrouching applies a strong downward gravity, letting you descend quickly.\n","bold": false,"color": "black"},{"text": "Cooldown: 0s","bold":false,"color":"dark_gray"}],\
\
[{"text": "Dragon Breath\n","bold": true,"color": "#5c2787"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Shoot a stream of dragon breath in a straight line. Deals damage to any runner caught in the projectile's path.","bold": false,"color": "black"},{"text": "\nCooldown: 2s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Charged Breath Attack\n","bold": true,"color": "#5c2787"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Charge for 4 seconds, then release a powerful burst of dragon breath. Deals heavy damage on a direct hit and leaves a lingering dragon's breath cloud at the point of impact.","bold": false,"color": "black"},{"text": "\nCooldown: 30s","bold": false,"color": "dark_gray"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "#5c2787"},{"text": "Tips for Runners\n\n","bold": true,"color": "gray","italic": true},{"text": "Fighting the Dragon is primarily about using cover. Indoors or under overhangs, the Dragon cannot easily angle breath attacks and cannot maintain flight height. Dense indoor areas heavily limit their mobility advantage.","bold": false,"color": "black"}]\
]}]