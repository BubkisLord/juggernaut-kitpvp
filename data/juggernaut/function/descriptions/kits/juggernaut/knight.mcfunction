item replace entity @s hotbar.8 with written_book[written_book_content={title:"Knight",author:"§9Server",pages:[\
[{"text": "Knight\n\n","bold": true,"color": "#C8B400"},\
 {"text": "A heavily armoured warrior who charges down foes with a powerful lance.","bold": false,"color": "black"}],\
\
[{"text": "Knight's Lance\n","bold": true,"color": "#C8B400"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Your lance charges over 5 seconds, gaining lunge distance with each stage. At full charge it deals maximum lunge distance. Does not charge on horseback.","bold": false,"color": "black"}],\
\
[{"text": "Summon Steed\n","bold": true,"color": "#C8B400"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Summon a skeleton horse to ride at greater speeds and lance your opponents. Use Dismiss Steed to send it away.","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "#C8B400"},{"text": "When the knight is on his horse running into him and staying inside the horse means he cannot lance you. As knight has no info abilities, ghost is a good pick as it is excellent for stealthing away from the juggernaut and avoiding chase entirely.","bold": false,"color": "black"}]]\
}]