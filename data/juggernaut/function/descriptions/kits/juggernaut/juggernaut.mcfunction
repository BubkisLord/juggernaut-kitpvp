item replace entity @s hotbar.8 with written_book[written_book_content={pages:[[{"text": "Classic Juggernaut\n\n","bold": true,"color": "dark_blue","underlined": false},{"text": "This simplistic kit focuses on good pathing and hitting heavy axe critical hits on your targets to deal maximum damage.","bold": false,"color": "black"}],\
[{"text": "Heavy Axe\n","bold": true,"color": "dark_blue"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "Your axe deals an extra 7 hearts of damage, but charges much slower. This means that getting a critical hit does exactly 10 hearts, enough to one-shot a runner on full health (no health or armor modifiers)","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "dark_blue"},{"text": "Counterplay for classic juggernaut is about either keeping distance or causing the juggernaut to hit you with an uncharged attack. As classic juggernaut has limited mobility, playing a kit with speed is excellent here. However, perks giving speed to classic juggernaut are often chosen.","bold": false,"color": "black"}]],title:"Classic Juggernaut",author:"§9Server"}]
