item replace entity @s hotbar.8 with written_book[written_book_content={title:"Predator",author:"§9Server",pages:[\
[{"text": "Predator\n\n","bold": true,"color": "#245018","underlined": false},\
 {"text": "This stealthy kit excels at sneaking up to its prey and executing a swift kill.","bold": false,"color": "black"}],\
 \
[{"text": "Camouflage\n","bold": true,"color": "#245018"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You are invisible, but emit dust and darkness particles around you to players within 20 blocks. While crouching, you no longer emit these particles and become ","bold": false,"color":"black"},{"text": "Undetectable","italic":true,"color": "red", "hover_event":{"action":"show_text","value":"You cannot be revealed by the glowing effect."}},{"text":". Your crouch speed is tripled.","bold": false,"color": "black"}],\
\
[{"text": "Thick Hide\n","bold": true,"color": "#245018"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You have constant resistance one.","bold": false,"color": "black"}],\
\
[{"text": "Thrill of the Hunt\n","bold": true,"color": "#245018"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You move at 110% speed.","bold": false,"color": "black"}],\
\
[{"text": "Seasoned Hunter\n","bold": true,"color": "#245018"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "While you are not in chase, you hear the direction of the nearest player's footsteps.","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "#245018"},{"text": "Counterplay for predator is, like other juggernauts lacking mobility, making distance. Predator can still use its stealth to cut off loops so runners should be wary of this. Other strategies include using the environment to your advantage, such as scout using fences to make distance.","bold": false,"color": "black"}]]}\
]
