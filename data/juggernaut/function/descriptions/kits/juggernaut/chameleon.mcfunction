item replace entity @s hotbar.8 with written_book[written_book_content={title:"Chameleon",author:"§9Server",pages:[\
[{"text": "Chameleon\n\n","bold": true,"color": "#b5ee4a","underlined": false},\
 {"text": "A deceptive infiltrator that mimics runners to blend in and strike from the shadows.","bold": false,"color": "black"}],\
\
[{"text": "Disguised Presence\n","bold": true,"color": "#b5ee4a"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You do not trigger the warning particles runners normally see when near a Replenishment Station. Instead, you emit replenishment particles when within 3 blocks of one.","bold": false,"color": "black"}],\
\
[{"text": "Camouflage\n","bold": true,"color": "#b5ee4a"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "While shapeshifting, you cannot enter chase and are ","bold": false,"color": "black"},{"text": "Undetectable","italic": true,"color": "red","hover_event":{"action":"show_text","value":"You cannot be revealed by the glowing effect."}},{"text": ". If your mannequin is killed by any means, your shapeshift is broken.","bold": false,"color": "black"}],\
\
[{"text": "Clone Player\n","bold": true,"color": "#b5ee4a"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Look at a runner within 6 blocks to mark them as your shapeshift target. They will be used for future Shapeshift and Swap with Runner actions.","bold": false,"color": "black"}],\
\
[{"text": "Shapeshift\n","bold": true,"color": "#b5ee4a"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Become invisible and summon a mannequin mimicking your cloned target, fooling nearby runners. If no target is cloned, you shapeshift into a random runner.","bold": false,"color": "black"}],\
\
[{"text": "Randomised Shapeshift\n","bold": true,"color": "#b5ee4a"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Immediately shapeshift into a random runner without needing to clone a target first.","bold": false,"color": "black"}],\
\
[{"text": "Exit Shapeshift\n","bold": true,"color": "#b5ee4a"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Dismiss your mannequin and return to your true form.","bold": false,"color": "black"}],\
\
[{"text": "Swap with Runner\n","bold": true,"color": "#b5ee4a"},{"text": "Active Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Instantly swap positions with your cloned target. If no target is cloned, swaps with a random runner.","bold": false,"color": "black"}],\
\
[{"text": "Thick Hide\n","bold": true,"color": "#b5ee4a"},{"text": "Passive Effect\n\n","bold": true,"color": "gray","italic": true},{"text": "You have constant resistance one.","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "#b5ee4a"},{"text": "Counterplay for chameleon is primarily good communication between runners. As chameleon is undetectable in shapeshift, scout may actually utilise this by looking for the absence of the glowing effect to know when chameleon is shapeshifting.","bold": false,"color": "black"}]\
]\
}]