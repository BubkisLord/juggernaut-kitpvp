item replace entity @s hotbar.8 with written_book[written_book_content={pages:[[{"text": "Witch Doctor\n\n","bold": true,"color": "dark_purple","underlined": false},{"text": "The Witch Doctor kit gives the user various potion buffs and the ability to enlarge other players and reduce yourself. Additionally, you are given damage potions which replenish periodically when standing next to a replenishment station.","bold": false,"color": "black"}],\
[{"text": "Damage Potions\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Gives you three throwable potions that deal instant magic damage.","bold": false,"color": "black"}],\
[{"text": "Speed Buff\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Gives 45 seconds of speed.","bold": false,"color": "black"}],\
[{"text": "Fire Resistance Buff\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Gives 45 seconds of fire resistance.","bold": false,"color": "black"}],\
[{"text": "Strength Buff\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Gives 45 seconds of strength.","bold": false,"color": "black"}],\
[{"text": "Enlarge\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Enlarges all runners within 8 blocks, causing 60% larger size, -30% movement speed, higher step height, and higher jumps.","bold": false,"color": "black"}],\
[{"text": "Reduce\n","bold": true,"color": "dark_purple"},{"text": "Activated Ability\n\n","bold": true,"color": "gray","italic": true},{"text": "Reduces your size and increases your movement speed.","bold": false,"color": "black"}],\
\
[{"text": "Counterplay\n","bold": true,"color": "dark_purple"},{"text": "Counterplay for witch doctor includes avoiding indoor areas where you will be enlarged, and when enlarged abusing the jump boost gained. Witch doctor catches rotations easily with his trail ability so medic and engineer are good picks to avoid needing to rotate as often.","bold": false,"color": "black"}]],title:"Witch Doctor",author:"§9Server"}]