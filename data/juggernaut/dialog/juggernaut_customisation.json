{
    "title": "Juggernaut",
    "type": "minecraft:notice",
    "action": {
        "label": "Save Modified Settings",
        "action": {
            "type": "dynamic/run_command",
            "template": "function juggernaut:save_dialog_options {\"juggernaut_count\": $(juggernaut_count), \"round_robin\": $(round_robin), \"completable_stations\": $(completable_stations), \"perks_enabled\": $(perks_enabled)}"
        }
    },
    "inputs": [
        {
            "key": "juggernaut_count",
            "type": "minecraft:number_range",
            "label": "Juggernaut Count",
            "start": 1,
            "end": 5,
            "label_format": "chat.type.text",
            "step": 1
        },
        {
            "key": "round_robin",
            "type": "boolean",
            "label": "Round Robin Juggernaut Selection?",
            "initial": true,
            "on_false": "0",
            "on_true": "1"
        },
        {
            "key": "completable_stations",
            "type": "boolean",
            "label": "Completable Stations?",
            "initial": true,
            "on_false": "0",
            "on_true": "1"
        },
        {
            "key": "perks_enabled",
            "type": "boolean",
            "label": "Perks Enabled?",
            "initial": true,
            "on_false": "0",
            "on_true": "1"
        }
    ],
    "can_close_with_escape": true
}